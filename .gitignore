# Ignore diagnostics and generated analysis tables from the alternate-lines pipeline
multi_output_threshold_mlp/diagnostics/
multi_output_threshold_mlp/*_predictions.csv
multi_output_threshold_mlp/walk_forward_stacked_pair_type_summary.csv

# Ignore bulky or nonessential local data, but keep the small current odds snapshots
# that the live app tabs rely on.
data/historical_odds_api/
